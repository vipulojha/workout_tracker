<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Welcome!"
            android:textColor="@color/accent_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="Let's build your profile"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Your current weight (kg)"
            android:textColor="@color/text_secondary" />

        <EditText
            android:id="@+id/etWeight"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_auth_field"
            android:hint="e.g. 75"
            android:inputType="numberDecimal"
            android:paddingStart="16dp"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Your height (cm)"
            android:textColor="@color/text_secondary" />

        <EditText
            android:id="@+id/etHeight"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_auth_field"
            android:hint="e.g. 180"
            android:inputType="number"
            android:paddingStart="16dp"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="What is your primary goal?"
            android:textColor="@color/text_secondary" />

        <Spinner
            android:id="@+id/spinnerGoal"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_auth_field"
            android:paddingStart="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Select specific focus area"
            android:textColor="@color/text_secondary" />

        <Spinner
            android:id="@+id/spinnerFocus"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_auth_field"
            android:paddingStart="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Your fitness level"
            android:textColor="@color/text_secondary" />

        <Spinner
            android:id="@+id/spinnerLevel"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_auth_field"
            android:paddingStart="12dp" />

        <Button
            android:id="@+id/btnCompleteOnboarding"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_primary_button"
            android:text="Finish Setup"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
